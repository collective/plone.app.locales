msgstr "Introduza unha ruta ou URL para o ficheiro de regras do tema."

#. Default: "Find users whose email address contain"
#: plone/app/users/browser/membersearch.py:31
msgid "help_search_email"
msgstr "Atopar usuarios cuxo enderezo de correo electrónico conteña"

#. Default: "Find users whose full names contain"
#: plone/app/users/browser/membersearch.py:38
