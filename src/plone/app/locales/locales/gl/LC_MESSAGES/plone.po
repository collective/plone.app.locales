msgstr "Prema para desactivar a función de importación de icalendar neste contexto."

#. Default: "Click to enable the icalendar import feature on this context."
#: plone/app/event/profiles/default/actions.xml
msgid "help_ical_import_enable"
msgstr "Prema para activar a función de importación de icalendar neste contexto."

#. Default: "Controls what types are addable in this location"
#: plone/app/content/browser/constraintypes.py:76
